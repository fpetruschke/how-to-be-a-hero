#!/usr/bin/env bash
# Aktiviert die versionierten Git-Hooks unter `.githooks/` für dieses Clone.
#
# Hintergrund: Git-Hooks unter `.git/hooks/` werden nicht mit ge-pusht und
# müssen pro Clone aktiviert werden. Über `core.hooksPath` lässt sich der
# Hook-Pfad einmalig auf das versionierte `.githooks/`-Verzeichnis zeigen.
#
# Idempotent — beliebig oft ausführbar.

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

if [[ ! -d .githooks ]]; then
  echo "Fehler: Verzeichnis .githooks fehlt im Repo." >&2
  exit 1
fi

git config core.hooksPath .githooks
chmod +x .githooks/* 2>/dev/null || true

echo "Git-Hooks aktiviert (core.hooksPath = .githooks)."
echo "Aktive Hooks:"
for hook in .githooks/*; do
  [[ -f "$hook" ]] || continue
  marker="✓"
  [[ -x "$hook" ]] || marker="!"
  printf '  %s %s\n' "$marker" "$(basename "$hook")"
done
echo
echo "Notbremse einmalig deaktivierbar mit:"
echo "  git commit --no-verify    # pre-commit überspringen"
echo "  git push   --no-verify    # pre-push überspringen"
